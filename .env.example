# ═══════════════════════════════════════════════════════════════════
#  HORDSTAKE — Environment Variables
#  Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════

SECRET_KEY=your-very-secret-key-change-this-now-in-production
DEBUG=False

# On Render, add DATABASE_URL automatically from your PostgreSQL add-on
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Optional: set ALLOWED_HOSTS if needed
# ALLOWED_HOSTS=yourdomain.onrender.com
